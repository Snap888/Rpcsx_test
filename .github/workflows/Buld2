name: Test Release

on:
  workflow_dispatch:

jobs:
  create-release:
    runs-on: ubuntu-latest
    steps:
    - name: Checkout
      uses: actions/checkout@v4

    - name: Create test file
      run: |
        echo "Test file created at $(date -u +%Y-%m-%d_%H:%M:%S)" > test-release.txt
        echo "Repository: ${{ github.repository }}" >> test-release.txt
        echo "Run ID: ${{ github.run_id }}" >> test-release.txt
        echo "Actor: ${{ github.actor }}" >> test-release.txt
        echo "---" >> test-release.txt
        echo "This is a test release file." >> test-release.txt
        cat test-release.txt

    - name: Create Release
      uses: softprops/action-gh-release@v2
      with:
        token: ${{ secrets.RELEASE_TOKEN2 }}
        tag_name: test-release-${{ github.run_number }}
        name: Test Release #${{ github.run_number }}
        body: |
          This is a test release.
          - Run: ${{ github.run_number }}
          - Commit: ${{ github.sha }}
          - Actor: ${{ github.actor }}
        files: test-release.txt
        prerelease: true
